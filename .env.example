# tsbench-forge — local secrets & knobs. Gitignored; never commit real keys.
# Nothing auto-loads this file: load it with `set -a; source .env; set +a`
# (or direnv / your process manager) before running the scraper or agent.

# ---------------------------------------------------------------- required
# Source-discovery agent, full run only (`python -m source_discovery --out ...`).
# --coverage / --dry-run / --vet / --assess work without it.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional overrides (defaults shown)
# OPENROUTER_MODEL=z-ai/GLM-5.2
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_TEMPERATURE=0.4
# Reasoning models (GLM, o-series, R1) spend most of the completion budget on
# hidden reasoning — with the proposal ledger in the prompt, 8000 reliably
# starves them (finish_reason=length). 32000 keeps the failure rate low; the
# client retries once at 2x on exhaustion.
OPENROUTER_MAX_TOKENS=32000
# OPENROUTER_TIMEOUT=120

# ------------------------------------------------- per-source scraper keys
# All optional and free; a missing key only disables that one source.

# EIA (Henry Hub natural gas requires it; NYIS demand falls back to DEMO_KEY)
# https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# OpenAQ air quality — https://explore.openaq.org/register
OPENAQ_API_KEY=

# Banxico SIE FX/rates — https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_TOKEN=

# GitHub personal access token (only raises rate limits; no scopes needed)
GITHUB_TOKEN=

# NYC Open Data app token — https://data.cityofnewyork.us/profile/edit/developer_settings
NYC_OPENDATA_TOKEN=

# Singapore LTA DataMall — https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_ACCOUNT_KEY=

# Not keys — polite User-Agent strings these APIs ask for, e.g.
# "tsbench-forge (you@tensor-link.com)"
REDDIT_USER_AGENT=
CRATESIO_USER_AGENT=
SEC_USER_AGENT=

# ------------------- keys for discovered candidate sources (2026-07-04 autoresearch)
# Needed to activate the top autoresearch candidates once they enter sources.yaml.

# PurpleAir PM2.5 sensor network (2-min cadence — fills the healthcare/sub-hourly gap)
# Free key: https://develop.purpleair.com/keys
PURPLEAIR_API_KEY=

# ENTSO-E Transparency Platform (energy outage/unavailability events)
# Register at https://transparency.entsoe.eu/ then My Account Settings -> Web API Security Token
ENTSOE_SECURITY_TOKEN=

# Global Fishing Watch (vessel encounter events)
# Free token: https://globalfishingwatch.org/our-apis/tokens
GFW_API_TOKEN=

# NIST NVD CVE API works keyless (5 req/30s); optional key raises to 50 req/30s:
# https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# PJM Data Miner 2 — api.pjm.com is connection-blocked from the AU scrape host;
# only useful if the cron moves. https://apiportal.pjm.com/
# PJM_SUBSCRIPTION_KEY=

# ------------------------------------------------------------------- knobs
# TSBENCH_STRONG=statsforecast   # swap panel anchor to AutoETS (needs statsforecast)
# SCRAPER_LOG_LEVEL=INFO
# TSBENCH_FEED_CACHE=~/.cache/tsbench-forge/feeds
# HF_HOME=                       # pre-staged HF weight cache for TSFM adapters

# ------ keys for 2026-07-05 ledger-round candidates (all free registrations)
# abuse.ch platforms (URLhaus / MalwareBazaar / ThreatFox) share one Auth-Key:
# https://auth.abuse.ch/ -> profile -> Auth-Key  (sent as Auth-Key header)
ABUSECH_AUTH_KEY=

# Trakt TV (trending shows, PT15M-ish attention series)
# https://trakt.tv/oauth/applications -> create app -> use the Client ID
TRAKT_CLIENT_ID=

# Finnhub market news event stream — https://finnhub.io/register
FINNHUB_TOKEN=

# US BEA (GDP/personal income, quarterly) — https://apps.bea.gov/api/signup/
BEA_API_KEY=

# TriMet GTFS-RT service alerts — https://developer.trimet.org/appid/registration/
TRIMET_APP_ID=

# AEMET Spanish weather observations — https://opendata.aemet.es/centrodedescargas/altaUsuario
AEMET_API_KEY=

# OpenEnergyMonitor emoncms (needs a public feed id too) — https://emoncms.org
# EMONCMS_API_KEY=
# BoardGameGeek XMLAPI2 has no key program; its 401s are bot-walling — no var to add.

# ------ keys for sweep-2 candidates (2026-07-06 vetting; all free registrations)
# USDA NASS Quick Stats (agricultural production, weekly/monthly)
# https://quickstats.nass.usda.gov/api -> request API key
USDA_NASS_API_KEY=

# ODPT Japan public transport (train status, irregular) — https://developer.odpt.org
ODPT_ACCESS_TOKEN=

# Schiphol flight movements — https://developer.schiphol.nl (app id + key pair)
SCHIPHOL_APP_ID=
SCHIPHOL_APP_KEY=

# FAA NOTAM API — https://api.faa.gov (external API portal, client credentials)
FAA_NOTAM_CLIENT_ID=
FAA_NOTAM_CLIENT_SECRET=

# Sonatype OSS Index (vulnerability disclosures) — https://ossindex.sonatype.org
OSSINDEX_API_TOKEN=

# Heavier OAuth setups — only if wanted:
# EBAY_OAUTH_TOKEN=        # https://developer.ebay.com (browse API)
# METACULUS_API_TOKEN=     # metaculus.com account settings
